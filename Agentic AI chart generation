    "plt.legend(title='Year')\n",
    "\n",
    "### Save the figure\n",
    "plt.savefig('chart_v1.png', dpi=300)\n",
    "\n",
    "### Close all plots\n",
    "plt.close()\n",
    "</execute_python>"
